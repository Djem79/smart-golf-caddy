VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GOOGLE_PLACES_API_KEY=

# Optional. Leave blank for local dev — Sentry is a no-op without a DSN.
# Create a project at https://sentry.io to get one.
VITE_SENTRY_DSN=

# Optional. App Check reCAPTCHA v3 site key. Blank = App Check off (dev/CI).
# Register the web app under Firebase console → App Check (reCAPTCHA v3) to
# get this. Enforcement on the Cloud Functions callables is enabled ONLY
# after this is deployed and tokens appear in the console — see SETUP.md.
VITE_APP_CHECK_SITE_KEY=
# Optional. A debug token (Firebase console → App Check → Manage debug
# tokens) so local dev / preview can pass App Check without real reCAPTCHA.
VITE_APP_CHECK_DEBUG_TOKEN=
