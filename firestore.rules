rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can read/write only their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rounds.
    // Reads: any authenticated user (needed so lobby join can find by code).
    // Create: hostId must match auth uid; the creating user must be the only
    //   player at creation time.
    // Update: allowed if the user is the host, OR is already a participant,
    //   OR is joining an open lobby (round status is 'lobby').
    // Delete: only the host.
    match /rounds/{roundId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.playerIds is list
        && request.auth.uid in request.resource.data.playerIds;

      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid
        || request.auth.uid in resource.data.playerIds
        || resource.data.status == 'lobby'
      );

      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }
  }
}
