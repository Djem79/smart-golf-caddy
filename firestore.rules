rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can read/write only their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rounds: anyone authenticated can read; only the host or existing players
    // can write. New rounds must list the creating user as host.
    match /rounds/{roundId} {
      allow read: if request.auth != null;

      // Create: only if the creating user is set as host AND included in players.
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.players[request.auth.uid] != null;

      // Update: only the host, or a player already in the players map (so guests
      // can record their own shots once joined). No one else can modify the round.
      allow update: if request.auth != null
        && (
          resource.data.hostId == request.auth.uid
          || resource.data.players[request.auth.uid] != null
        );

      // Delete: only the host can delete the round.
      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }
  }
}
