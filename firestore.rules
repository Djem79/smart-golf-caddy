rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — each user owns only their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user share quota (userQuota/{uid}) — Admin SDK only. Clients must
    // never read or write this document; the shareRoundByEmail Cloud Function
    // is the sole writer.
    match /userQuota/{userId} {
      allow read, write: if false;
    }

    // Rounds — field-aware update rules split per action.
    match /rounds/{roundId} {

      // READ
      // `get` requires participation. The lobby-bypass exception was removed
      // because it exposed PII (full players map + emails + lobbyCode) to any
      // authenticated attacker. Join-by-code now goes through a callable
      // function (`joinLobbyByCode`) that uses Admin SDK.
      allow get: if request.auth != null
        && resource.data.playerIds is list
        && request.auth.uid in resource.data.playerIds;

      // `list` is left permissive (authed only) for `getUserRounds` which
      // queries by `playerIds array-contains <auth.uid>` — Firestore evaluates
      // per-doc get rules during list, so non-participant docs are filtered.
      allow list: if request.auth != null;

      // CREATE — host creates a round with themselves as the only player.
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.playerIds is list
        && request.resource.data.playerIds.size() == 1
        && request.resource.data.playerIds[0] == request.auth.uid
        && request.resource.data.status in ['lobby', 'active']
        && request.resource.data.totalHoles in [9, 18];

      // UPDATE — one of four per-action rules must match. Shot recording
      // (formerly rule 5) moved to a callable function (`recordShotV2`)
      // because per-shot dot-path enforcement is not expressible in rules.
      // No client may write `holes`, `emailedAt`, `emailingStartedAt`, or
      // `emailedTo` directly — those belong to the server.
      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['holes', 'emailedAt', 'emailingStartedAt', 'emailedTo', 'emailResults'])
        && (
          // 1. JOIN — open lobby, user adding themselves to players
          (
            resource.data.status == 'lobby'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'playerIds'])
            && request.auth.uid in request.resource.data.playerIds
            && request.resource.data.playerIds.size() <= 8
            && request.resource.data.players[request.auth.uid] != null
            // lobby code / host / status / course / holes / totalHoles must not change
            && request.resource.data.hostId == resource.data.hostId
            && request.resource.data.lobbyCode == resource.data.lobbyCode
            && request.resource.data.status == resource.data.status
            && request.resource.data.courseId == resource.data.courseId
            && request.resource.data.courseName == resource.data.courseName
            && request.resource.data.totalHoles == resource.data.totalHoles
          )
          // 2. LEAVE — user removing only themselves from playerIds
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerIds'])
            && !(request.auth.uid in request.resource.data.playerIds)
            && (request.auth.uid in resource.data.playerIds)
          )
          // 3. START — host transitions lobby → active
          || (
            resource.data.hostId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startedAt'])
            && resource.data.status == 'lobby'
            && request.resource.data.status == 'active'
          )
          // 4. FINISH — host transitions active → finished
          || (
            resource.data.hostId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'finishedAt'])
            && resource.data.status == 'active'
            && request.resource.data.status == 'finished'
          )
        );

      // DELETE — host only
      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid;
    }
  }
}
